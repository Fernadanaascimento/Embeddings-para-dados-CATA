import numpy as np

def area_elipse(X, conf=0.95):

    cov = np.cov(X, rowvar=False)
    vals, _ = np.linalg.eigh(cov)

    chi2_val = chi2.ppf(conf, df=2)

    width, height = 2 * np.sqrt(vals * chi2_val)

    area = np.pi * (width/2) * (height/2)

    return area


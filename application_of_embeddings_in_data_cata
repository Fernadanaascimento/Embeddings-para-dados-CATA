# Modelo multilíngue adequado para termos em português
modelo_bert = SentenceTransformer('paraphrase-multilingual-mpnet-base-v2')

# Cache para evitar reprocessamento do mesmo termo emocional
embed_cache = {}

def embed_token(token):
    """
    Retorna embedding de um termo emocional.
    Utiliza cache para evitar recomputação.
    """
    if token not in embed_cache:
        embed_cache[token] = modelo_bert.encode(token)
    return embed_cache[token]

# 2) Função de processamento por ambiente
# ----------------------------------------------------------

def processar_ambiente(df, ambiente_nome):
    """
    Filtra o ambiente, gera embeddings médios por participante,
    aplica normalização L2 e executa PCA (2 componentes).
    Retorna coordenadas PCA e variância explicada e matriz normalizada.
    """

    # Filtra ambiente específico
    df_amb = df[df['Ambientes'] == ambiente_nome].reset_index(drop=True)

    # Remove observações sem marcação emocional
    df_amb = df_amb[df_amb['emoções_list'].map(len) > 0].reset_index(drop=True)

    # Lista de emoções por participante
    token_lists = df_amb['emoções_list'].tolist()

    # Determina padding máximo necessário
    max_tokens = max(len(lst) for lst in token_lists)

    # Dimensão do embedding (768)
    emb_dim = embed_token(token_lists[0][0]).shape[0]

    n = len(token_lists)

    # Estrutura tridimensional: (participantes, emoções, dimensão)
    X_emb = np.zeros((n, max_tokens, emb_dim), dtype=np.float32)
    mask = np.zeros((n, max_tokens), dtype=np.float32)

    # Preenchimento da matriz de embeddings com máscara
    for i, tokens in enumerate(token_lists):
        for j, t in enumerate(tokens):
            X_emb[i, j, :] = embed_token(t)
            mask[i, j] = 1.0

    # Mean pooling ponderado pela máscara
    # Gera vetor médio emocional por participante
    X_mean = (X_emb * mask[..., None]).sum(axis=1) / \
             (mask.sum(axis=1)[:, None] + 1e-8)

    # Normalização L2
    # Remove efeito de magnitude e aproxima distância euclidiana da similaridade angular
    X_norm = normalize(X_mean, norm='l2')

    # PCA para visualização bidimensional
    pca = PCA(n_components=2)
    X_pca = pca.fit_transform(X_norm)

    # Variância explicada (%)
    var_exp = pca.explained_variance_ratio_ * 100

    return X_pca, var_exp, X_norm, df_amb

import matplotlib.patches as patches
from scipy.stats import chi2

def adicionar_elipse(ax, X, conf=0.95):
    """
    Adiciona elipse de confiança baseada na distribuição bivariada.
    """
    # Média
    mean = np.mean(X, axis=0)

    # Matriz de covariância
    cov = np.cov(X, rowvar=False)

    # Autovalores e autovetores
    vals, vecs = np.linalg.eigh(cov)

    # Ordena do maior para o menor
    order = vals.argsort()[::-1]
    vals = vals[order]
    vecs = vecs[:, order]

    # Ângulo da elipse
    theta = np.degrees(np.arctan2(*vecs[:,0][::-1]))

    # Raio baseado no qui-quadrado
    chi2_val = chi2.ppf(conf, df=2)
    width, height = 2 * np.sqrt(vals * chi2_val)

    # Cria elipse
    ellipse = patches.Ellipse(
        xy=mean,
        width=width,
        height=height,
        angle=theta,
        edgecolor='black',
        facecolor='none',
        linewidth=1.5
    )

    ax.add_patch(ellipse)

